# App
APP_ENV=development # production or development로 환경 분리 할 용도로다가
APP_HOST=0.0.0.0 
APP_PORT=8000

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=dangmagochi
POSTGRES_USER=dangmagochi_user
POSTGRES_PASSWORD=dangmagochi_pass
DATABASE_URL=postgresql://dangmagochi_user:dangmagochi_pass@db:5432/dangmagochi

# JWT
JWT_SECRET_KEY=
